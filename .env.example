# Cloudflare Worker 認証トークン（必須）
# CF Dashboardのワーカー設定またはDriveの.envファイルから取得
CF_ADMIN_TOKEN=your_cloudflare_admin_token_here

# Cloudflare Worker URL（省略可 - デフォルト値あり）
CF_WORKER_URL=https://x-realestate-autopost.univcorp2.workers.dev/run

# EstateBoardのreceivedフォルダパス（省略可）
# Windowsの場合はバックスラッシュをエスケープするかスラッシュを使う
ESTATEBOARD_PATH=G:\マイドライブ\AI_Agents\github\repos\EstateBoard\output\received
